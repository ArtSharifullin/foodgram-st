# Kubernetes namespace to deploy into
NAMESPACE=foodgram
# Helm release name
RELEASE_NAME=foodgram

# Vault AppRole credentials used by helm-secrets/vals to resolve secrets
VAULT_ADDR=http://vault.vault.svc.cluster.local:8200
VAULT_ROLE_ID=changeme-role-id
VAULT_SECRET_ID=changeme-secret-id
VAULT_KV_MOUNT=secrets
